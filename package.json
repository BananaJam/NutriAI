  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@sinclair/typebox": "^0.34.48",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "latest",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "openapi-types": "^12.1.3",
    "playwright-core": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "prisma",
