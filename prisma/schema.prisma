generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Better Auth Models ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]

  profile       UserProfile?
  settings      UserSettings?
  foodLogs      FoodLog[]
  mealPlans     MealPlan[]
  goals         Goal[]
  conversations Conversation[]
  foodFavorites UserFoodFavorite[]
  agentLabRuns  AgentLabRun[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ==================== App Models ====================

model UserProfile {
  id             String        @id @default(cuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth    DateTime?
  gender         Gender?
  height         Float?
  weight         Float?
  activityLevel  ActivityLevel @default(MODERATE)
  targetCalories Int?
  targetProtein  Float?
  targetCarbs    Float?
  targetFat      Float?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("user_profiles")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

model UserSettings {
  id                       String                 @id @default(cuid())
  userId                   String                 @unique
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  themePreference          ThemePreference        @default(SYSTEM)
  defaultDashboardRange    DashboardRange         @default(DAYS_30)
  compactMode              Boolean                @default(false)
  startWeekOn              WeekStart              @default(MONDAY)
  showCaloriesOnDashboard  Boolean                @default(true)
  showProteinOnDashboard   Boolean                @default(true)
  showStreakOnDashboard    Boolean                @default(true)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@map("user_settings")
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum DashboardRange {
  DAYS_7
  DAYS_30
  DAYS_90
}

enum WeekStart {
  MONDAY
  SUNDAY
}

model Food {
  id          String   @id @default(cuid())
  name        String
  brand       String?
  servingSize Float
  servingUnit String   @default("g")
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sugar       Float?
  sodium      Float?
  barcode     String?  @unique
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  foodLogs      FoodLogItem[]
  mealPlanItems MealPlanItem[]
  favorites     UserFoodFavorite[]

  @@index([name])
  @@map("foods")
}

model UserFoodFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, foodId])
  @@index([userId, createdAt])
  @@map("user_food_favorites")
}

model FoodLog {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime      @db.Date
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     FoodLogItem[]

  @@unique([userId, date])
  @@map("food_logs")
}

model FoodLogItem {
  id        String   @id @default(cuid())
  foodLogId String
  foodLog   FoodLog  @relation(fields: [foodLogId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id])
  mealType  MealType
  servings  Float    @default(1)
  notes     String?
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("food_log_items")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model MealPlan {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime       @db.Date
  endDate   DateTime       @db.Date
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     MealPlanItem[]

  @@map("meal_plans")
}

model MealPlanItem {
  id         String   @id @default(cuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  foodId     String
  food       Food     @relation(fields: [foodId], references: [id])
  dayOfWeek  Int
  mealType   MealType
  servings   Float    @default(1)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("meal_plan_items")
}

model Goal {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         GoalType
  targetValue  Float
  currentValue Float      @default(0)
  unit         String
  startDate    DateTime   @db.Date
  endDate      DateTime?  @db.Date
  status       GoalStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("goals")
}

enum GoalType {
  WEIGHT_LOSS
  WEIGHT_GAIN
  CALORIE_TARGET
  PROTEIN_TARGET
  WATER_INTAKE
  CUSTOM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  toolCalls      Json?
  toolResults    Json?
  createdAt      DateTime     @default(now())

  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AgentLabRun {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sdk            AgentLabSdk
  scenarioId     AgentLabScenario
  conversationId String?
  prompt         String
  response       String?
  status         AgentLabRunStatus @default(PENDING)
  latencyMs      Int?
  error          String?
  rawTrace       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  toolEvents     AgentLabToolEvent[]

  @@index([userId, createdAt])
  @@index([userId, sdk, scenarioId])
  @@map("agent_lab_runs")
}

model AgentLabToolEvent {
  id        String                @id @default(cuid())
  runId     String
  run       AgentLabRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  position  Int
  toolName  String
  state     AgentLabToolEventState
  args      Json?
  result    Json?
  createdAt DateTime              @default(now())

  @@index([runId, position])
  @@map("agent_lab_tool_events")
}

enum AgentLabSdk {
  VERCEL_AI
  OPENAI_AGENTS
  LANGGRAPH
}

enum AgentLabScenario {
  HIGH_PROTEIN_BREAKFAST
  LOG_RECENT_LUNCH
  WEEKLY_NUTRITION_REVIEW
  CALCULATE_MACROS
}

enum AgentLabRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AgentLabToolEventState {
  CALL
  RESULT
  ERROR
}
